<svg width="680" height="420" viewBox="0 0 680 420" role="img" xmlns="http://www.w3.org/2000/svg">
  <title>Rogue Coding logo</title>
  <desc>Rogue Coding logo centered both horizontally and vertically with hexagon mark above company name</desc>

  <style>
    .logo-name { font-family: Arial, sans-serif; font-weight: 700; font-size: 42px; fill: #FFFFFF; letter-spacing: 2px; }
    .logo-tag  { font-family: Arial, sans-serif; font-weight: 400; font-size: 15px; fill: #E94560; letter-spacing: 6px; }
    .code-comment { font-family: Arial, sans-serif; font-size: 11px; fill: #0F3460; letter-spacing: 1px; }
  </style>

  <rect width="680" height="420" rx="12" fill="#1A1A2E"/>

  <g transform="translate(225, 42)">
    <line x1="115" y1="-6" x2="115" y2="-24" stroke="#0F3460" stroke-width="2"/>
    <circle cx="115" cy="-30" r="6" fill="#E94560"/>

    <polygon points="115,0 165,28 165,84 115,112 65,84 65,28" fill="#0F3460" stroke="#E94560" stroke-width="2"/>
    <polygon points="115,14 153,36 153,80 115,102 77,80 77,36" fill="#1A1A2E"/>

    <text x="115" y="52" text-anchor="middle" font-family="Arial" font-weight="700" font-size="22" fill="#E94560">&lt;/&gt;</text>
    <text x="115" y="76" text-anchor="middle" font-family="Arial" font-weight="400" font-size="11" fill="#C8D0E0">RC</text>

    <line x1="65" y1="56" x2="40" y2="56" stroke="#E94560" stroke-width="1.5" stroke-dasharray="3,3"/>
    <line x1="165" y1="56" x2="190" y2="56" stroke="#E94560" stroke-width="1.5" stroke-dasharray="3,3"/>

    <rect x="95" y="128" width="40" height="6" rx="3" fill="#0F3460"/>
    <rect x="100" y="138" width="30" height="6" rx="3" fill="#0F3460" opacity="0.6"/>
  </g>

  <text x="340" y="244" text-anchor="middle" class="logo-name">ROGUE CODING</text>
  <text x="340" y="276" text-anchor="middle" class="logo-tag">WEB · AI · BUILT DIFFERENT</text>

  <line x1="170" y1="288" x2="510" y2="288" stroke="#E94560" stroke-width="1.5"/>
  <line x1="170" y1="292" x2="510" y2="292" stroke="#0F3460" stroke-width="0.5" opacity="0.6"/>

  <text x="340" y="316" text-anchor="middle" class="code-comment">// upload logo + business plan → live site in minutes</text>

  <rect x="40" y="20" width="600" height="380" rx="8" fill="none" stroke="#0F3460" stroke-width="0.75" opacity="0.5"/>
  <rect x="44" y="24" width="592" height="372" rx="6" fill="none" stroke="#E94560" stroke-width="0.5" opacity="0.25"/>
</svg>
